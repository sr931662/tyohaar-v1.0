# Tyohaar API — environment variables
#
# Copy this file to `.env` and fill in real values. Never commit the actual
# `.env` file — only this `.env.example` template belongs in version control.

# ── Application ───────────────────────────────────────────────────────────
APP_NAME=Tyohaar API
APP_VERSION=1.0.0
# One of: development | staging | production
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────────────────
# Must be a PostgreSQL connection string (postgresql:// or postgresql+asyncpg://).
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>/<database>?sslmode=require

# ── Security / JWT ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be at least 32 characters long.
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list or JSON array. In production, lock this to the exact
# frontend origin(s) — do NOT leave as "*" once real traffic is live.
# Example: https://tyohaar.co,https://www.tyohaar.co
ALLOWED_ORIGINS=*

# ── Trusted Hosts ─────────────────────────────────────────────────────────
# Comma-separated list. In production, lock this to your Cloud Run hostname
# and any custom domain(s) — do NOT leave as "*" once real traffic is live.
# Example: tyohaar-v1-0-xxxxxxxxxxxx.asia-south1.run.app,tyohaar.co,www.tyohaar.co
ALLOWED_HOSTS=*

# ── Pagination ────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ── OTP ───────────────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_MAX_RESENDS=3

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── Upload ────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10

# ── OAuth — Google Sign-In ────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth Client ID (Web).
# Leave blank in dev; Google Sign-In endpoints return a clear error until set.
GOOGLE_CLIENT_ID=

# ── Image/File Storage — Cloudinary ───────────────────────────────────────
# cloudinary.com → Dashboard → Product Environment Credentials.
# Leave blank in dev; the image/file upload endpoint returns a clear error until set.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Payment Gateway — Razorpay ────────────────────────────────────────────
# dashboard.razorpay.com → Settings → API Keys, for RAZORPAY_KEY_ID/SECRET.
# dashboard.razorpay.com → Settings → Webhooks, for RAZORPAY_WEBHOOK_SECRET
# (set when creating the webhook endpoint — a separate secret from the API keys).
# Leave blank in dev; payment initiation/webhook endpoints return a clear
# error until set.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Email — Gmail SMTP (App Password) ─────────────────────────────────────
# Requires 2-Step Verification enabled on the Gmail account. Generate an App
# Password at myaccount.google.com/apppasswords ("Mail" → your device name).
# SMTP_USERNAME is the full Gmail address; SMTP_PASSWORD is the 16-character
# app password (spaces in the pasted value are fine, they're stripped).
# SMTP_FROM_EMAIL defaults to SMTP_USERNAME when left blank.
# Leave SMTP_USERNAME/SMTP_PASSWORD blank in dev; OTP emails and other
# transactional emails return a clear error until set.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Tyohaar

# ── Server process (used by run.py, not by app/core/config.py) ───────────
HOST=0.0.0.0
PORT=8000
RELOAD=true
WORKERS=1
LOG_LEVEL=info

# ── One-off scripts (scripts/seed_admin.py only — not read by the app) ───
ADMIN_PHONE=+919999999999
ADMIN_EMAIL=admin@tyohaar.com
ADMIN_NAME=Superadmin
ADMIN_PASSWORD=
